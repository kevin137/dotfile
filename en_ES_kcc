LC_MESSAGES
% + is ised in many applications for yes (- for no)
% 1 is common yes, 0 is common no, - langage neutral
% sS is Spanish/Italian "si"
% yY is English "yes"
yesexpr "^[+1yYsS]"
noexpr  "^[-0nN]"
yesstr  "yes"
nostr   "no"
END LC_MESSAGES

LC_PAPER
