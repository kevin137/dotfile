% Install with something like this:
%   sudo localedef -i ~/proj/waah/dotfile/en_ES_kcc -f UTF-8 -v en_ES_kcc.UTF-8
%   locale -a
%   cat << EOF >> .profile 
%   export LANG=en_ES_kcc.UTF-8
%   export LC_ALL=en_ES_kcc.UTF-8
%   EOF

LC_IDENTIFICATION
